/* Estilos globales de la app. CSS único (SPEC §12.3) — no usar CSS inline en widgets.
 *
 * Estética: refresh estilo OpenCode / Claude Code (tema `tokyo-night` activado
 * desde `App.theme`). Bordes finos y sutiles. La jerarquía visual la dan el
 * peso de texto y el color de acento; los bordes son secundarios. Excepción:
 * algunos "cards" de realce (callouts de estado, viewers) usan `border: round`
 * con tinte del acento para destacar bloques puntuales (ver
 * `#preview-base-result-scroll`, `#configure-product-info`).
 */

/* ============================================================================
 * Spacing scale (mínimo 2 NO-CERO, escala 2-friendly, simetría visual 1:2)
 *
 * IMPORTANTE: en una TUI una celda de caracter NO es cuadrada — mide
 * aproximadamente el doble de alto que de ancho (~1:2). Por eso un
 * `padding: 2 2` (numéricamente "simétrico") **se ve asimétrico** al ojo:
 * 2 cells arriba/abajo ocupan ~32px visualmente, 2 cells izq/der ocupan
 * ~16px. Resultado: el borde superior e inferior parece el doble de
 * grueso que los laterales.
 *
 * REGLA: para padding/margin shorthand, el valor horizontal debe ser el
 * DOBLE del vertical para verse simétrico al ojo.
 *
 * Pares canónicos (vertical : horizontal):
 *
 *   padding: 1 2     ← compacto simétrico
 *   padding: 2 4     ← cómodo simétrico (preferido)
 *   padding: 3 6     ← generoso simétrico
 *   padding: 4 8     ← muy generoso simétrico
 *
 * Para padding/margin de un solo lado (padding-top, margin-left), la
 * escala es: 2, 4, 8, 12, 16, 20, 24, 28, ...
 *
 * Donde:
 *   - 2 es el mínimo (granularidad fina).
 *   - 4, 8, 12, ... son los espacios cómodos (preferidos).
 *   - 0 solo se permite como "ausencia de spacing en ese eje", NO como
 *     spacing reducido (`margin: 0 2` = sin margen vertical, 2 horizontal).
 *
 * Excepciones documentadas (NO ampliar sin justificación explícita):
 *   - `height: 1` en barras de status y counters de 1 línea (texto puro).
 *   - `height: 3` en Button (1 visual + 2 chrome interno de Textual).
 *   - `min-width: 1` / `width: 1fr` en columnas fluidas (no son medidas).
 *   - `padding-top: 0` en `.actions-row` (margin-top: 2 ya separa, sumar
 *     padding empuja botones fuera del bounding del padre Vertical).
 *   - **Botones de texto**: ancho dinámico por contenido vía `Button {
 *     width: auto, min-width: 12, padding: 0 2 }`. Ningún Button con
 *     label de texto debe tener `width: NUM` o `min-width > 12`.
 *
 * Tokens reutilizables del theme tokyo-night:
 *   $boost                     → cards y botones default
 *   $surface                   → fondos de modales
 *   $primary-background        → backgrounds dimmed (tablas, viewers)
 *   $primary-background-lighten-2 → borders sutiles (línea fina)
 *   $accent                    → títulos, énfasis sutil
 *   $primary                   → botón primary, focus
 *   $error                     → botón destructive, mensajes de error
 *   $text                      → texto principal
 *   $text-muted                → descripciones secundarias / hints
 * ============================================================================ */

Screen {
    align: center middle;
    background: $background;
}

/* ----------------------------------------------------------------------------
 * Botones alto contraste: todos los botones tienen borde visible, texto bold y
 * foco fuerte. En hover/active invertimos color de texto/fondo para que la
 * interacción sea clara incluso en terminales con bajo contraste.
 * -------------------------------------------------------------------------- */

/* ----------------------------------------------------------------------------
 * Sistema de variantes de Button (v1.4.0 — familia visual unificada)
 *
 * Todos los botones comparten:
 *   - Mismo height (3), padding (0 2), min-width (12), border tall.
 *   - text-style: bold en TODA variante para mejorar legibilidad.
 *   - Estado :hover / .-active con inversión de contraste.
 *
 * Tres tiers, cada uno con un rol visual claro:
 *
 *   Tier 1 — fill sólido + bold (call-to-action prominente, 1 por dialog)
 *     .-primary  → lavanda  → encolar / guardar / generar / confirmar
 *     .-error    → rojo     → eliminar / cancelar cola / acciones irreversibles
 *
 *   Tier 2 — fill sólido semántico (acciones secundarias)
 *     .btn-info     → cyan/accent  → leer / ver / preview / abrir / copiar / refrescar
 *     .btn-success  → verde        → aprobar / confirmar OK (raro)
 *     .btn-warning  → amarillo     → reintentar / cancelar job / pausar / detener
 *
 *   Tier 3 — neutral relleno (cerrar / volver, sin compromiso)
 *     .-default  → surface-lighten-1  → Cancelar / Cerrar / dismiss
 *
 *   Helpers compactos (no son tier semántico, solo presentación):
 *     .btn-filter  → toggle tipo radio para filtros (history / queue)
 * -------------------------------------------------------------------------- */

Button {
    border: tall $primary-background-lighten-2;
    height: 3;          /* 1 visual + 2 chrome interno Textual (excepción) */
    width: auto;        /* dinámico por contenido (CR-3.7 consistencia) */
    min-width: 12;      /* piso para tap targets sin labels muy cortos */
    padding: 0 2;       /* 2 cells de aire a ambos lados del label */
    text-style: bold;
    background: $primary-background-lighten-2;
    color: $text;
}

Button:focus {
    border: double $accent;
    background: $accent;
    color: $background;
    text-style: bold;
}

Button:hover {
    background: $accent;
    border: tall $accent;
    color: $background;
}

Button.-active {
    background: $accent-darken-1;
    border: tall $accent-lighten-2;
    color: $text;
    tint: transparent;
}

/* === Tier 1 — fills sólidos =============================================== */

Button.-primary {
    background: $primary;
    color: $background;
    border: tall $primary-lighten-1;
    text-style: bold;
}

Button.-primary:hover {
    background: $primary-lighten-1;
    color: $background;
    border: tall $primary-lighten-1;
}

Button.-primary.-active {
    background: $primary-darken-1;
    color: $text;
    border: tall $primary-lighten-1;
}

Button.-error {
    background: $error;
    color: $background;
    border: tall $error-lighten-1;
    text-style: bold;
}

Button.-error:hover {
    background: $error-lighten-1;
    color: $background;
    border: tall $error-lighten-1;
}

Button.-error.-active {
    background: $error-darken-1;
    color: $text;
    border: tall $error-lighten-1;
}

/* === Tier 2 — tints coloreados ============================================ */

Button.btn-info,
Button.btn-success,
Button.btn-warning {
    text-style: bold;
}

Button.btn-info {
    background: $accent;
    color: $background;
    border: tall $accent-lighten-1;
}

Button.btn-info:hover {
    background: $accent-lighten-1;
    color: $background;
    border: tall $accent-lighten-2;
}

Button.btn-info.-active {
    background: $accent-darken-1;
    color: $text;
    border: tall $accent-lighten-2;
}

Button.btn-success {
    background: $success;
    color: $background;
    border: tall $success-lighten-1;
}

Button.btn-success:hover {
    background: $success-lighten-1;
    color: $background;
    border: tall $success-lighten-2;
}

Button.btn-success.-active {
    background: $success-darken-1;
    color: $text;
    border: tall $success-lighten-2;
}

Button.btn-warning {
    background: $warning;
    color: $background;
    border: tall $warning-lighten-1;
}

Button.btn-warning:hover {
    background: $warning-lighten-1;
    color: $background;
    border: tall $warning-lighten-2;
}

Button.btn-warning.-active {
    background: $warning-darken-1;
    color: $text;
    border: tall $warning-lighten-2;
}

/* === Tier 3 — default / cerrar ============================================ */

Button.-default {
    background: $surface-lighten-1;
    color: $text;
    border: tall $surface-lighten-2;
}

Button.-default:hover {
    background: $primary-background-lighten-2;
    border: tall $accent;
}

Button.-default.-active {
    background: $primary-background-lighten-2;
    border: tall $accent;
}

/* === Helpers compactos ==================================================== */

Button:disabled {
    background: $surface;
    color: $text-muted;
    text-style: none;
    border: tall $primary-background-lighten-2;
}

/* ----------------------------------------------------------------------------
 * Layout primitives compartidas (escala 1/2/4)
 * -------------------------------------------------------------------------- */

.section-label {
    color: $text-muted;
    padding-top: 2;
    text-style: bold;
}

.field-row {
    height: auto;
    padding: 2 4;
}

.actions-row {
    height: 3;
    align: center middle;
    /* `padding-top: 0` deliberado: el espaciado lo da `margin-top: 2` con
     * el bloque superior. Sumar padding-top adicional empuja los botones
     * fuera del bounding del padre Vertical en viewports compactos. */
    padding-top: 0;
    margin-top: 2;
}

.actions-row Button {
    /* Margin horizontal entre botones; vertical 0 para no overflowear la
     * row de height: 3. La separacion visual contra otros widgets la da
     * `actions-row.margin-top`. */
    margin: 0 2;
    height: 3;
}

/* Botones de acciones en filas múltiples. Cada uno se ajusta dinámicamente
 * al ancho de su texto + padding interno simétrico definido por el base
 * `Button { padding: 0 2; width: auto }` — esta regla solo override del
 * `min-width: 12` global para permitir labels muy cortos ("Ver", "Quitar")
 * en filas densas de tablas.
 *
 * Antes había duplicación de `width: auto; padding: 0 2` acá y otras
 * variantes específicas (`actions-row-save { width: 28 }`,
 * `#video-form-footer Button { width: 22 }`). Esas reglas fueron removidas
 * en v1.4.0: el ancho lo decide el contenido SIEMPRE, sin excepciones. */
.actions-row-keys Button {
    min-width: 0;
}

.clipboard-paste-button {
    margin-top: 1;
}

#status-bar {
    color: $accent;
    padding-top: 2;
    content-align: center middle;
    height: 1;          /* 1 linea de texto (excepción) */
}

/* ----------------------------------------------------------------------------
 * Componentes Textual ajustados al theme
 * -------------------------------------------------------------------------- */

OptionList {
    height: auto;
    background: $surface;
    border: none;
    padding: 2 4;
}

/* Cursor del menu principal: background sutil + acento. */
OptionList:focus > .option-list--option-highlighted {
    background: $boost-lighten-1;
    color: $accent;
    text-style: bold;
}

DataTable {
    background: $primary-background;
    color: $text;
}

DataTable > .datatable--header {
    background: $primary-background-lighten-1;
    color: $accent;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: $primary;
    color: $text;
}

DataTable > .datatable--hover {
    background: $boost;
}

TabbedContent {
    height: 1fr;
}

TabPane {
    padding: 2 4;
}

Tabs {
    background: transparent;
}

Collapsible {
    border: none;
    padding: 2;
}

CollapsibleTitle {
    color: $accent;
    text-style: bold;
}

/* ============================================================================
 * Main menu
 * ============================================================================ */

#menu-box {
    width: 80%;
    min-width: 60;
    max-width: 80;
    height: auto;
    border: none;
    background: $surface;
    padding: 2 4;
}

#title {
    content-align: center middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 2;
}

#hint {
    color: $text-muted;
    content-align: center middle;
    padding-top: 2;
}

/* ============================================================================
 * Settings screen
 * ============================================================================ */

SettingsScreen {
    align: center top;
}

#settings-box {
    width: 90%;
    max-width: 112;
    height: 90%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#settings-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 2;
    height: 3;
}

#keys-table {
    height: 1fr;
    min-height: 4;
}

/* ============================================================================
 * Images screen
 * ============================================================================ */

ImagesScreen {
    align: center top;
}

#images-box {
    width: 95%;
    height: 95%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#images-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 2;
    height: 3;
}

#images-table {
    height: 1fr;
    min-height: 4;
}

#images-hint {
    color: $text-muted;
    height: auto;
    padding-top: 2;
    content-align: center middle;
}

#images-credits {
    height: auto;       /* deja crecer con padding sin recortar el texto */
    content-align: right middle;
    padding: 0 4;
    margin-top: 1;
}

/* ============================================================================
 * UploadImage modal
 * ============================================================================ */

UploadImageFormScreen {
    align: center middle;
}

#image-form-dialog {
    width: 80;
    max-width: 95%;
    height: auto;
    /* Sin borde: el contraste de `$surface` contra el fondo del
     * MainScreen ya marca el modal. Coherente con `#audio-form-dialog`
     * y `#video-form-dialog`. */
    border: none;
    background: $surface;
    padding: 2 4;
}

#image-form-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 2;
}

#image-path-row {
    height: auto;
    align: left middle;
}

#image-path-row Input {
    width: 1fr;
}

#image-path-row Button {
    margin-left: 2;
}

#image-form-error {
    color: $error;
    padding-top: 2;
    height: auto;
}

/* ============================================================================
 * File picker modal
 * ============================================================================ */

ImageFilePickerScreen {
    align: center middle;
}

#file-picker-dialog {
    width: 92;
    max-width: 95%;
    height: 90%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#file-picker-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 2;
    height: 3;
}

#file-picker-tree {
    height: 1fr;
    background: $surface;
    border: none;
}

#file-picker-status {
    color: $text-muted;
    padding-top: 2;
    height: 1;
}

/* ============================================================================
 * Logs screen
 * ============================================================================ */

LogsScreen {
    align: center top;
}

#logs-box {
    width: 95%;
    height: 95%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#logs-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 2;
}

#logs-view {
    height: 1fr;
    background: $primary-background;
    border: none;
}

/* ============================================================================
 * Audios screen
 * ============================================================================ */

AudiosScreen {
    align: center top;
}

#audios-box {
    width: 95%;
    height: 95%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#audios-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 2;
    height: 3;
}

#audios-table {
    height: 1fr;
    min-height: 4;
}

#audios-hint {
    color: $text-muted;
    height: auto;
    padding-top: 2;
    content-align: center middle;
}

#audios-credits {
    height: auto;       /* deja crecer con padding sin recortar el texto */
    content-align: right middle;
    padding: 0 4;
    margin-top: 1;
}

/* Panel de contadores en vivo de la cola de audios (Etapa 4).
 * Una sola línea con [🔄 generando · ⏳ en cola · ✓ listos · ✖ fallidos].
 * Padding lateral consistente con el resto del box para que las cuentas
 * queden alineadas con la tabla de abajo. */
#audios-counters {
    height: 1;
    content-align: center middle;
    padding: 0 4;
    margin-bottom: 1;
}

/* ============================================================================
 * History screen (vista unificada video + audio)
 * ============================================================================ */

HistoryScreen {
    align: center top;
}

#history-box {
    width: 95%;
    height: 95%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#history-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 2;
    height: 3;
}

#history-summary {
    height: 1;
    content-align: center middle;
    padding: 0 4;
    margin-bottom: 1;
}

#history-filters {
    margin-bottom: 1;
}

/* Toggle filter buttons: rellenos para conservar la misma familia visual que
 * los botones de acción. */
Button.btn-filter {
    background: $primary-background-lighten-2;
    color: $text;
    border: tall $surface-lighten-2;
}

Button.btn-filter:hover {
    background: $accent;
    color: $background;
    border: tall $accent-lighten-2;
    text-style: bold;
}

Button.btn-filter:focus {
    border: double $accent;
    text-style: bold;
}

Button.btn-filter.-active {
    background: $accent;
    color: $background;
    border: tall $accent-lighten-2;
    text-style: bold;
}

#history-table {
    height: 1fr;
    min-height: 4;
}

#history-hint {
    color: $text-muted;
    height: auto;
    padding-top: 2;
    content-align: center middle;
}

/* ============================================================================
 * Queue screen (vista operativa de jobs no-completados)
 * ============================================================================ */

QueueScreen {
    align: center top;
}

#queue-box {
    width: 95%;
    height: 95%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#queue-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 2;
    height: 3;
}

#queue-summary {
    height: 1;
    content-align: center middle;
    padding: 0 4;
    margin-bottom: 1;
}

#queue-filters {
    margin-bottom: 1;
}

/* Las dos rows de acciones: la primera para acciones por fila
 * (cancel/retry del seleccionado), la segunda para bulk (todos
 * los queued / todos los failed). Aire entre ellas y aire del
 * hint debajo. */
#queue-actions {
    margin-top: 1;
}

#queue-table {
    height: 1fr;
    min-height: 4;
}

#queue-hint {
    color: $text-muted;
    height: auto;
    padding-top: 2;
    content-align: center middle;
}

/* ============================================================================
 * GenerateAudio modal
 * ============================================================================ */

GenerateAudioFormScreen {
    align: center middle;
}

#audio-form-dialog {
    /* Width 120: el footer tiene 4 botones (Cancelar, Guardar preset,
     * Generar y otro, Generar). Con el ancho dinámico de v1.4.0 (base
     * `Button { width: auto, padding: 0 2 }`), 120 cells dan aire de
     * sobra para los labels largos sin recortar. */
    width: 120;
    max-width: 95%;
    height: auto;
    border: none;
    background: $surface;
    padding: 1 3;
    overflow: hidden;
    layout: vertical;
}

#audio-form-body {
    /* `height: auto` sin max-height para que se contraiga al contenido. */
    height: auto;
    overflow-y: auto;
    overflow-x: hidden;
    /* Padding interno del body adicional al padding del dialog para
     * tener doble aire (más cómodo visualmente que un único margen
     * grande en el dialog). */
    padding: 0 1;
    scrollbar-size-vertical: 1;
}

#audio-form-footer {
    height: 3;
    align: center middle;
    /* Padding lateral mínimo: la separación visual la dan el
     * `margin: 0 2` entre botones + el padding del dialog. */
    padding: 0 1;
    /* Margin-top más generoso para separar claramente la zona de
     * acciones del cuerpo del form. */
    margin-top: 2;
}

#audio-form-footer Button {
    /* Solo margen y altura — el ancho lo decide el base Button + contenido. */
    margin: 0 2;
    height: 3;
}

#audio-form-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    /* padding-bottom: 1 para separar el título del primer Label.
     * Sin esto, "Generar audio TTS..." quedaba pegado a "Label
     * legible" sin línea de aire en medio. */
    padding-bottom: 1;
}

#audio-script {
    height: 8;
    /* margin-top: 0 — el Label inmediatamente arriba ya separa. */
}

#audio-script-counter {
    color: $text-muted;
    content-align: right middle;
    height: 1;
    /* Margin-bottom para separar el contador del Label "Voz" siguiente. */
    margin-bottom: 1;
}

#audio-voice-row {
    height: auto;
    align: left middle;
    /* Margin-bottom para separar de "Avanzado". */
    margin-bottom: 1;
}

#audio-voice-row Select {
    width: 1fr;
}

#audio-voice-row Button {
    margin-left: 2;
}

/* Botón "Detener" del preview de audio: usa el base Button (width: auto,
 * min-width: 12). El comentario histórico documentaba un width:4 para
 * mostrar solo el emoji "⏹"; al cambiar a label "Detener" alcanza con
 * el piso base de 12 cells para ambos states. */

#audio-advanced {
    margin-top: 0;
    /* Override del DEFAULT_CSS de Collapsible: quitamos border-top y
     * padding-bottom para que cuando esté COLAPSADO ocupe solo la
     * línea del título. Cuando se expanda, el content tiene su
     * propio padding y queda bien. */
    border-top: none;
    padding: 0;
}

/* Espacio entre Label y el widget siguiente — todos los Label dentro
 * del body. Hace que la jerarquía sea visualmente clara: cada Label
 * "etiqueta" el campo de abajo, separado del bloque anterior. */
#audio-form-body Label {
    margin-top: 1;
}

#audio-form-error {
    color: $error;
    padding: 0;
    height: auto;
    margin-top: 1;
}

/* ============================================================================
 * KeyForm modal
 * ============================================================================ */

KeyFormScreen {
    align: center middle;
}

#key-form-dialog {
    width: 72;
    max-width: 90%;
    height: auto;
    /* Sin borde: el contraste de `$surface` contra el fondo dimmed del
     * MainScreen ya marca el modal. Coherente con `#audio-form-dialog`,
     * `#video-form-dialog`, `#image-form-dialog` y `#gen-image-dialog`. */
    border: none;
    background: $surface;
    padding: 2 4;
}

#key-form-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 2;
}

#key-form-error {
    color: $error;
    padding-top: 2;
    height: auto;
}

/* ============================================================================
 * Videos screen (cola de VideoJob — Kling AI Avatar Pro)
 * ============================================================================ */

VideosScreen {
    align: center top;
}

#videos-box {
    width: 95%;
    height: 95%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#videos-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 2;
    height: 3;
}

#videos-counters {
    height: 1;
    content-align: center middle;
    padding: 0 4;
    margin-bottom: 1;
}

#videos-table {
    height: 1fr;
    min-height: 4;
}

#videos-hint {
    color: $text-muted;
    height: auto;
    padding-top: 2;
    content-align: center middle;
}

/* ============================================================================
 * NewVideo modal (mismo patrón sticky-footer que GenerateAudio)
 * ============================================================================ */

NewVideoFormScreen {
    align: center middle;
}

#video-form-dialog {
    width: 100;
    max-width: 95%;
    height: auto;
    border: none;
    background: $surface;
    /* Padding generoso — coherente con #audio-form-dialog. */
    padding: 1 3;
    overflow: hidden;
    layout: vertical;
}

#video-form-body {
    height: auto;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 1;
    scrollbar-size-vertical: 1;
}

#video-form-footer {
    height: 3;
    align: center middle;
    padding: 0 1;
    margin-top: 2;
}

#video-form-footer Button {
    /* Solo margen y altura — el ancho lo decide el base Button + contenido. */
    margin: 0 2;
    height: 3;
}

#video-form-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
}

#video-prompt {
    height: 10;
}

#video-prompt-counter {
    color: $text-muted;
    content-align: right middle;
    height: 1;
    margin-bottom: 1;
}

#video-audio-row {
    height: auto;
    align: left middle;
    margin-bottom: 1;
}

#video-audio-row Select {
    width: 1fr;
}

#video-audio-row Button {
    margin-left: 2;
}

/* `#video-audio-stop` usa el base Button (width: auto, min-width: 12) —
 * sin override, coherente con `#audio-preview-stop` y resto de glyphs. */

/* Labels dentro del body: separados del contenido anterior con
 * margin-top, igual que el modal de audio. */
#video-form-body Label {
    margin-top: 1;
}

.form-warning {
    color: $warning;
    padding: 0;
    height: auto;
    margin-top: 1;
}

#video-form-error {
    color: $error;
    padding: 0;
    height: auto;
    margin-top: 1;
}

/* ============================================================================
 * Presets screen (CRUD de voice presets)
 * ============================================================================ */

PresetsScreen {
    align: center top;
}

#presets-box {
    width: 95%;
    height: 95%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#presets-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
    height: 3;
}

#presets-subtitle {
    height: auto;
    content-align: left middle;
    margin-bottom: 1;
}

#presets-table {
    height: 1fr;
    min-height: 4;
}

#presets-hint {
    color: $text-muted;
    height: auto;
    padding-top: 2;
    content-align: center middle;
}

/* ============================================================================
 * PresetForm modal
 * ============================================================================ */

PresetFormScreen {
    align: center middle;
}

#preset-form-dialog {
    width: 100;
    max-width: 95%;
    height: auto;
    max-height: 90%;
    border: none;
    background: $surface;
    padding: 1 3;
    overflow: hidden;
    layout: vertical;
}

#preset-form-body {
    height: 1fr;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 1;
    scrollbar-size-vertical: 1;
}

#preset-form-footer {
    height: 3;
    align: center middle;
    padding: 0 1;
    margin-top: 1;
}

#preset-form-footer Button {
    /* Solo margen y altura — el ancho lo decide el base Button + contenido. */
    margin: 0 2;
    height: 3;
}

#preset-form-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
}

#preset-form-body Label {
    margin-top: 1;
}

#preset-voice-row {
    height: auto;
    align: left middle;
}

#preset-voice-row Select {
    width: 1fr;
}

#preset-voice-row Button {
    margin-left: 2;
}

#preset-description {
    height: 4;
}

#preset-advanced {
    margin-top: 0;
    border-top: none;
    padding: 0;
}

#preset-form-error {
    color: $error;
    padding: 0;
    height: auto;
    margin-top: 1;
}

/* ============================================================================
 * BatchScreen — procesar lote desde batch_jobs/
 * ============================================================================ */

BatchScreen {
    align: center top;
}

#batch-box {
    width: 95%;
    height: 95%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#batch-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
    height: 3;
}

#batch-subtitle {
    height: auto;
    content-align: left middle;
    margin-bottom: 1;
}

#batch-counters {
    height: 1;
    content-align: left middle;
    padding: 0;
    margin-bottom: 1;
}

#batch-table {
    height: 1fr;
    min-height: 4;
}

#batch-hint {
    color: $text-muted;
    height: auto;
    padding-top: 2;
    content-align: center middle;
}

/* ============================================================================
 * GenerateImage modal (Nano Banana 2)
 *
 * Mismo patrón sticky-footer que GenerateAudio: outer Vertical (no
 * scroll) + body scrollable + footer fijo abajo. Sin border para
 * coherencia con los otros modales (el contraste de `$surface` ya marca
 * el modal). TextAreas con altura acotada para que el modal no se
 * estire infinito y los Selects de settings en una sola fila lateral.
 * ============================================================================ */

GenerateImageFormScreen {
    align: center middle;
}

#gen-image-dialog {
    /* Width 120: footer con 3 botones de width auto + min-width 18,
     * más los 3 Selects horizontales del row de settings. */
    width: 120;
    max-width: 95%;
    height: auto;
    max-height: 90%;
    border: none;
    background: $surface;
    padding: 1 3;
    overflow: hidden;
    layout: vertical;
}

#gen-image-body {
    height: auto;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 1;
    scrollbar-size-vertical: 1;
}

#gen-image-footer {
    height: 3;
    align: center middle;
    padding: 0 1;
    margin-top: 2;
}

#gen-image-footer Button {
    /* Solo margen y altura — el ancho lo decide el base Button + contenido. */
    margin: 0 2;
    height: 3;
}

#gen-image-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
}

/* Labels dentro del body: igual patrón que audio/video. */
#gen-image-body Label {
    margin-top: 1;
}

/* TextArea del label: 1 línea visible (chico). Sin esto se estira al
 * tamaño del contenido y el body queda enorme. */
#gen-image-label {
    height: 3;
}

/* TextArea del prompt: 8 líneas visibles con scroll interno si crece. */
#gen-image-prompt {
    height: 8;
}

#gen-image-prompt-counter {
    color: $text-muted;
    content-align: right middle;
    height: 1;
    margin-bottom: 1;
}

/* Row horizontal con los 3 Selects (aspect_ratio, resolution, format). */
#gen-image-settings-row {
    height: auto;
    align: left middle;
    margin-bottom: 1;
}

#gen-image-settings-row .gen-image-setting {
    width: 1fr;
    height: auto;
    margin-right: 2;
}

/* ============================================================================
 * AutomationScreen + ConfigureWorkflow modal + WorkflowSummary modal +
 * WorkflowDetail screen
 *
 * Misma estructura visual que BatchScreen para AutomationScreen
 * (`width/height: 95%` + `padding: 2 4` para air alrededor del contenido,
 * que sin esto queda pegado a los bordes del Header/Footer).
 *
 * El modal `ConfigureWorkflowScreen` y el nuevo `WorkflowSummaryScreen`
 * siguen el patrón de `GenerateImageFormScreen`: dialog centrado con
 * `width: 120 max-width: 95%`, body scrollable, footer fijo con los
 * botones.
 * ============================================================================ */

AutomationScreen {
    align: center top;
}

#automation-box {
    width: 95%;
    height: 95%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#automation-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
    height: 3;
}

#automation-subtitle {
    height: auto;
    content-align: left middle;
    margin-bottom: 1;
}

#automation-counters {
    height: 1;
    content-align: left middle;
    margin-bottom: 1;
}

#automation-fs-table {
    /* Tabla del filesystem: alturas chicas (≤5 filas visibles típicas).
     * Si el usuario tiene muchos workflows en disco, scrollea dentro. */
    height: 1fr;
    min-height: 4;
    max-height: 30%;
    margin-bottom: 1;
}

#automation-db-table {
    /* Tabla del historial DB: ocupa el resto del espacio disponible. */
    height: 2fr;
    min-height: 4;
}

#automation-hint {
    color: $text-muted;
    height: auto;
    padding-top: 1;
    content-align: center middle;
}

#automation-status-bar {
    height: auto;
    content-align: left middle;
    padding-top: 1;
}

.section-title {
    height: 1;
    content-align: left middle;
    color: $accent;
    text-style: bold;
    margin-top: 1;
}

/* --- ConfigureWorkflowScreen modal --- */

ConfigureWorkflowScreen {
    align: center middle;
}

#configure-workflow-box {
    width: 100;
    max-width: 95%;
    height: auto;
    max-height: 90%;
    border: none;
    background: $surface;
    padding: 2 4;
    overflow: hidden;
    layout: vertical;
}

#configure-workflow-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
    height: 3;
}

#configure-workflow-subtitle {
    height: auto;
    content-align: left middle;
    margin-bottom: 1;
    color: $text-muted;
}

/* Región scrollable de los campos del formulario: título/subtítulo quedan
 * fijos arriba y los botones de acción fijos abajo, mientras los controles
 * (preset/duración/aprobación/producto) hacen scroll si no entran en
 * pantalla. Mismo patrón que #workflow-summary-body: `max-height` en % del
 * viewport + `height: auto` para contraerse a contenido en forms cortos. */
#configure-workflow-body {
    height: auto;
    max-height: 70%;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 1;
    scrollbar-size-vertical: 1;
}

#configure-workflow-box Static {
    height: auto;
}

#configure-workflow-box Input {
    margin-bottom: 1;
}

#configure-voice-changer-row {
    height: auto;
    margin-bottom: 1;
}

#configure-voice-changer-select {
    height: 3;
    width: auto;
    margin-bottom: 1;
}

#configure-voice-changer-value {
    color: $text;
    height: auto;
}

#configure-voice-changer-hint {
    color: $text-muted;
    height: auto;
    margin-bottom: 1;
}

#configure-hint {
    color: $text-muted;
    height: auto;
    margin-top: 1;
}

/* "Próximo paso / Atención": callout informativo del cierre del modal.
 * Card con borde lavanda (mismo color que el botón primary "Continuar")
 * para separarlo visualmente del muro de hints grises de arriba. */
#configure-warning {
    height: auto;
    color: $text;
    border: round $primary 60%;
    padding: 1 2;
    margin-top: 1;
    margin-bottom: 1;
}

#configure-status-bar {
    height: auto;
    content-align: left middle;
    padding-top: 1;
}

#configure-preset-row {
    height: 3;
    margin-bottom: 1;
}

#configure-preset-row Select {
    width: 1fr;
    margin-right: 1;
}

#configure-preset-row Button {
    margin-left: 1;
}

#configure-preset-hint {
    color: $text-muted;
    height: auto;
    margin-bottom: 1;
}

#configure-duration-label {
    height: 1;
    color: $accent;
    padding-top: 1;
}

#configure-duration-row {
    height: 3;
    margin-bottom: 1;
}

#configure-duration-row Select {
    width: 1fr;
}

#configure-duration-hint {
    color: $text-muted;
    height: auto;
    margin-bottom: 1;
}

/* --- Aprobación de scene_image (mismo patrón que el bloque de duración) --- */

#configure-approval-label {
    height: 1;
    color: $accent;
    padding-top: 1;
}

/* Altura fija como las demás filas de control. SIN esto, el `Horizontal`
 * toma `height: 1fr` por default y se expande para llenar el espacio
 * sobrante del scroll body, dejando un HUECO grande antes del hint. */
#configure-approval-row {
    height: 3;
    margin-bottom: 1;
}

#configure-approval-row Select {
    width: 1fr;
}

/* ---------------------------------------------------------------------------
 * Voice changer selector: modal hijo del ConfigureWorkflowScreen.
 * Mantiene el mismo patrón: card centrada, body scrolleable y filas de control
 * con altura fija para evitar que un Horizontal tome height: 1fr.
 * ------------------------------------------------------------------------ */

VoiceChangerSelectorScreen {
    align: center middle;
}

#voice-changer-selector-box {
    width: 100;
    max-width: 95%;
    height: auto;
    max-height: 90%;
    border: none;
    background: $surface;
    padding: 2 4;
    overflow: hidden;
    layout: vertical;
}

#voice-changer-selector-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
    height: 3;
}

#voice-changer-selector-body {
    height: auto;
    max-height: 72%;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 1;
    scrollbar-size-vertical: 1;
}

#voice-changer-selector-body Static {
    height: auto;
}

#voice-changer-selector-body Select,
#voice-changer-selector-body Input {
    width: 1fr;
    margin-bottom: 1;
}

#voice-changer-preview-row {
    height: 3;
    margin-bottom: 1;
}

#voice-changer-preview-row Button {
    margin-right: 1;
}

#voice-changer-selector-status {
    height: auto;
    color: $text-muted;
    margin-top: 1;
}

#configure-approval-hint {
    color: $text-muted;
    height: auto;
    margin-bottom: 1;
}

/* Producto promocional: es un ESTADO (activado), no un hint más. Card con
 * borde redondeado verde (mismo lenguaje visual que los cards del repo,
 * ver #preview-base-result-scroll) para que destaque del muro de hints. */
#configure-product-info {
    height: auto;
    border: round $success 60%;
    padding: 1 2;
    margin-top: 1;
    margin-bottom: 1;
}

/* --- WorkflowSummaryScreen modal (resumen pre-encolar) --- */

WorkflowSummaryScreen {
    align: center middle;
}

#workflow-summary-box {
    width: 110;
    max-width: 95%;
    height: auto;
    max-height: 90%;
    border: none;
    background: $surface;
    padding: 2 4;
    overflow: hidden;
    layout: vertical;
}

#workflow-summary-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
    height: 3;
}

#workflow-summary-body {
    height: auto;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 1;
    scrollbar-size-vertical: 1;
    max-height: 60%;
}

#workflow-summary-body Static {
    height: auto;
    margin-bottom: 1;
}

#workflow-summary-credits {
    color: $accent;
    text-style: bold;
    margin-top: 1;
}

#workflow-summary-warning {
    color: $warning;
    height: auto;
    margin-top: 1;
}

#workflow-summary-status-bar {
    height: auto;
    content-align: left middle;
    padding-top: 1;
}

/* --- WorkflowDetailScreen --- */

WorkflowDetailScreen {
    align: center top;
}

#workflow-detail-box {
    width: 95%;
    height: 95%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#workflow-detail-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
    height: 3;
}

#workflow-detail-meta {
    height: auto;
    content-align: left middle;
    margin-bottom: 1;
}

#workflow-detail-table {
    height: 1fr;
    min-height: 4;
}

#workflow-detail-status-bar {
    height: auto;
    content-align: left middle;
    padding-top: 1;
}

/* --- EditWorkflowStepScreen modal --- */

EditWorkflowStepScreen {
    align: center middle;
}

#edit-step-dialog {
    width: 110;
    max-width: 95%;
    height: auto;
    max-height: 90%;
    border: none;
    background: $surface;
    padding: 2 4;
    overflow: hidden;
    layout: vertical;
}

#edit-step-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
    height: 3;
}

#edit-step-subtitle {
    height: auto;
    color: $text-muted;
    padding-bottom: 1;
}

#edit-step-body {
    height: auto;
    max-height: 32;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 1;
    scrollbar-size-vertical: 1;
    border: round $primary 40%;
    margin-bottom: 1;
}

#edit-step-body TextArea {
    height: 5;
    margin-bottom: 1;
    border: round $primary 40%;
}

#edit-step-prompt {
    height: 9;
}

#edit-step-error {
    color: $error;
    height: auto;
    margin-top: 1;
}

#edit-step-footer {
    height: 3;
    align: right middle;
}

#edit-step-footer Button {
    margin-left: 1;
}

/* --- PreviewBaseImageScreen modal (preview de imagen base on-demand) --- */

PreviewBaseImageScreen {
    align: center middle;
}

#preview-base-box {
    width: 95%;
    height: 95%;
    border: none;
    background: $surface;
    padding: 2 4;
}

#preview-base-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
    height: 3;
}

#preview-base-subtitle {
    height: auto;
    color: $text-muted;
    padding-bottom: 1;
}

.preview-base-section {
    height: 1;
    color: $accent;
    padding-top: 1;
}

#preview-base-prompt-input {
    height: 10;
    margin-bottom: 1;
    border: round $primary 60%;
}

#preview-base-settings-row {
    height: 3;
    margin-bottom: 1;
}

#preview-base-settings-row Select {
    width: 1fr;
    margin-right: 1;
}

#preview-base-result-scroll {
    height: 1fr;
    min-height: 5;
    border: round $primary 40%;
    padding: 1 2;
    margin-bottom: 1;
}

#preview-base-result {
    height: auto;
}

#preview-base-loader {
    height: 3;
    margin-bottom: 1;
    display: none;
}

#preview-base-actions {
    height: 3;
    align: right middle;
}

#preview-base-actions Button {
    margin-left: 1;
}

/* --- SceneImageApprovalScreen modal (aprobacion humana scene_image) --- */

SceneImageApprovalScreen {
    align: center middle;
}

#scene-approval-box {
    width: 110;
    max-width: 95%;
    height: auto;
    max-height: 90%;
    border: none;
    background: $surface;
    padding: 2 4;
    overflow: hidden;
    layout: vertical;
}

#scene-approval-title {
    content-align: left middle;
    color: $accent;
    text-style: bold;
    padding-bottom: 1;
    height: 3;
}

#scene-approval-subtitle {
    height: auto;
    color: $text-muted;
    padding-bottom: 1;
}

#scene-approval-body {
    height: auto;
    max-height: 30;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 0 1;
    scrollbar-size-vertical: 1;
    border: round $primary 40%;
    margin-bottom: 1;
}

#scene-approval-body Static {
    height: auto;
    margin-bottom: 1;
}

#scene-approval-body TextArea {
    height: 5;
    margin-bottom: 1;
    border: round $primary 40%;
}

#scene-approval-prompt {
    height: 8;
}

#scene-approval-status {
    height: auto;
    color: $text;
    margin-top: 1;
}

#scene-approval-loader {
    height: 3;
    margin-bottom: 1;
    display: none;
}

#scene-approval-actions {
    height: 3;
    align: right middle;
}

#scene-approval-actions Button {
    margin-left: 1;
}

#gen-image-settings-row Select {
    width: 1fr;
}

/* SelectionList de referencias: altura fija con scroll interno para
 * evitar que el modal crezca cuando hay muchas imágenes. */
#gen-image-refs {
    height: 10;
    border: none;
    background: $boost;
    margin-top: 1;
}

#gen-image-refs-empty {
    color: $text-muted;
    height: auto;
    padding: 1;
}

#gen-image-error {
    color: $error;
    padding: 0;
    height: auto;
    margin-top: 1;
}
