# Copia este archivo a .env y completa los valores. NO subir .env a Git.

# Credenciales
KIE_API_KEY=

# Endpoints (defaults oficiales)
KIE_API_BASE=https://api.kie.ai
KIE_UPLOAD_BASE=https://kieai.redpandaai.co

# Ejecución
MAX_PARALLEL_JOBS=2
MAX_PARALLEL_AUDIO_JOBS=1
MAX_PARALLEL_IMAGE_JOBS=3
MAX_PARALLEL_VIDEO_JOBS=2
MAX_PARALLEL_UPLOAD_JOBS=2
MAX_PARALLEL_DOWNLOAD_JOBS=3
POLL_INTERVAL_SECONDS=10
TASK_TIMEOUT_SECONDS=1800

# Defaults
DEFAULT_VOICE=EkK5I93UQWFDigLMpZcX
DEFAULT_PROMPT=Mirada a cámara, expresión natural, gestos suaves, tono confiado.

# Notificaciones del SO al terminar un job (toast cross-platform).
# Linux requiere `libnotify-bin` (notify-send). Windows 10+ y macOS funcionan
# out-of-the-box. Si tu entorno headless no las soporta, dejá False.
NOTIFICATIONS_ENABLED=True

# Updater: chequea releases nuevos en GitHub al arrancar.
# - UPDATE_CHECK_ENABLED=False para deshabilitar (modo offline).
# - UPDATE_CHECK_REPO apunta al repo de releases; cambialo si forkeás.
UPDATE_CHECK_ENABLED=True
UPDATE_CHECK_REPO=ARosentiehl24/kie-avatar-studio

# Paths
DATA_DIR=./data
OUTPUTS_DIR=./outputs
INPUTS_DIR=./inputs
PRESETS_DIR=./presets
BATCH_JOBS_DIR=./batch_jobs
WORKFLOWS_DIR=./workflows
LOGS_DIR=./logs

# Workflows de automatización: cuántos pueden correr en paralelo.
# Cada workflow internamente ejecuta sub-jobs que respetan límites
# selectivos: AUDIO bajo (TTS es más inestable), IMAGE/VIDEO/UPLOAD/DOWNLOAD
# pueden ser más altos para mejorar throughput sin saturar TTS.
MAX_PARALLEL_WORKFLOWS=1

# Logs
LOG_LEVEL=INFO
