{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/kie-avatar-studio/workflows/SCHEMA.json",
  "title": "Kie Avatar Studio Workflow JSON (v2)",
  "description": "Contrato para workflows JSON consumidos por AutomationScreen / WorkflowLoader. Flujo v2: render por VEO + postproceso local (concat) + voice changer opcional.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow",
    "pre_settings",
    "run"
  ],
  "properties": {
    "workflow": {
      "type": "string",
      "minLength": 1,
      "description": "Nombre del workflow para UI y manifest."
    },
    "pre_settings": {
      "$ref": "#/$defs/PreSettings"
    },
    "run": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Step"
      },
      "description": "Lista ordenada de pasos (escenas) a ejecutar."
    }
  },
  "$defs": {
    "AspectRatio": {
      "type": "string",
      "enum": [
        "auto",
        "match_input_image",
        "1:1",
        "9:16",
        "16:9",
        "4:3",
        "3:4",
        "3:2",
        "2:3",
        "4:5",
        "5:4",
        "21:9",
        "9:21",
        "1:8",
        "4:1",
        "8:1"
      ],
      "description": "Aspect ratios generales aceptados por el validador de dominio."
    },
    "VeoSettings": {
      "type": "object",
      "additionalProperties": false,
      "description": "Configuración global de VEO usada para renderizar TODOS los pasos.",
      "properties": {
        "model": {
          "type": "string",
          "enum": [
            "veo3",
            "veo3_fast",
            "veo3_lite"
          ],
          "default": "veo3_fast"
        },
        "aspect_ratio": {
          "type": "string",
          "enum": [
            "16:9",
            "9:16",
            "Auto"
          ],
          "default": "9:16"
        },
        "resolution": {
          "type": "string",
          "enum": [
            "720p",
            "1080p",
            "4k"
          ],
          "default": "720p"
        },
        "duration": {
          "type": "integer",
          "enum": [
            4,
            6,
            8
          ],
          "default": 8
        },
        "enable_translation": {
          "type": "boolean",
          "default": true
        },
        "watermark": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "VoiceChangerSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "voice_id"
      ],
      "description": "Postproceso opcional sobre final_audio.mp3 usando ElevenLabs Speech-to-Speech.",
      "properties": {
        "voice_id": {
          "type": "string",
          "minLength": 1
        },
        "model_id": {
          "type": "string",
          "minLength": 1,
          "default": "eleven_multilingual_sts_v2"
        },
        "remove_background_noise": {
          "type": "boolean",
          "default": true
        },
        "output_format": {
          "type": "string",
          "minLength": 1,
          "default": "mp3_44100_128"
        },
        "voice_settings": {
          "oneOf": [
            {
              "$ref": "#/$defs/VoiceSettings"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Overrides opcionales enviados a ElevenLabs como voice_settings JSON string. language_code no aplica a speech-to-speech."
        }
      }
    },
    "VoiceSettings": {
      "type": "object",
      "additionalProperties": false,
      "description": "Ajustes opcionales de voz soportados por ElevenLabs speech-to-speech.",
      "properties": {
        "stability": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "similarity_boost": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "style": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "speed": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0.7,
          "maximum": 1.2
        }
      }
    },
    "ModelCreation": {
      "description": "Cómo resolver la imagen base del modelo antes de ejecutar pasos.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "prompt"
          ],
          "properties": {
            "method": {
              "const": "prompt"
            },
            "prompt": {
              "type": "string",
              "minLength": 1,
              "maxLength": 5000
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method"
          ],
          "properties": {
            "method": {
              "const": "local"
            },
            "local_path": {
              "type": "string",
              "description": "Ruta local opcional. Si no viene, la UI puede solicitarla al encolar."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "method",
            "asset_kind",
            "asset_id"
          ],
          "properties": {
            "method": {
              "const": "catalog"
            },
            "asset_kind": {
              "type": "string",
              "enum": [
                "uploaded",
                "generated"
              ]
            },
            "asset_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "PreSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_creation"
      ],
      "properties": {
        "model_creation": {
          "$ref": "#/$defs/ModelCreation"
        },
        "scene_approval_mode": {
          "type": "string",
          "enum": [
            "auto",
            "manual"
          ],
          "default": "auto"
        },
        "promote_product": {
          "type": "boolean",
          "default": false
        },
        "image_aspect_ratio": {
          "oneOf": [
            {
              "$ref": "#/$defs/AspectRatio"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "veo": {
          "$ref": "#/$defs/VeoSettings",
          "default": {}
        },
        "voice_changer": {
          "oneOf": [
            {
              "$ref": "#/$defs/VoiceChangerSettings"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      }
    },
    "Step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step",
        "scene_name",
        "type",
        "prompt"
      ],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1
        },
        "scene_name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "a-roll",
            "b-roll"
          ]
        },
        "attached": {
          "type": "boolean",
          "default": true,
          "description": "Si true, el clip participa en final.mp4; si false, se genera pero no se concatena."
        },
        "change_scene": {
          "type": "boolean",
          "default": true
        },
        "scene_description": {
          "type": "string",
          "default": ""
        },
        "change_background": {
          "type": "boolean",
          "description": "DEPRECATED: alias legacy de change_scene."
        },
        "background_description": {
          "type": "string",
          "description": "DEPRECATED: alias legacy de scene_description."
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "description": "Guion hablado. Requerido para a-roll; opcional para b-roll."
        },
        "voiceover": {
          "type": "boolean",
          "default": true,
          "description": "DEPRECATED: compatibilidad con pipeline legacy."
        },
        "duration_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 3,
          "maximum": 15,
          "description": "DEPRECATED: no controla la duración en flujo v2."
        },
        "include_product": {
          "type": "boolean",
          "default": false
        },
        "include_model": {
          "type": "boolean",
          "default": true
        },
        "set_as_base": {
          "type": "boolean",
          "default": false,
          "description": "Si true, la scene_image generada por este step pasa a ser la nueva base de los siguientes steps. Cuando existe al menos un step con set_as_base=true, el workflow se ejecuta en serie para preservar continuidad."
        },
        "product_prompt": {
          "type": "string",
          "default": ""
        },
        "image_aspect_ratio": {
          "oneOf": [
            {
              "$ref": "#/$defs/AspectRatio"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "a-roll"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "text"
            ],
            "properties": {
              "text": {
                "type": "string",
                "minLength": 1,
                "maxLength": 5000
              },
              "prompt": {
                "type": "string",
                "minLength": 1,
                "maxLength": 5000
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "b-roll"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "prompt": {
                "type": "string",
                "minLength": 1,
                "maxLength": 2500
              },
              "text": {
                "type": "string",
                "maxLength": 5000
              }
            }
          }
        }
      ]
    }
  }
}
